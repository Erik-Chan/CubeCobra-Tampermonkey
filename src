// ==UserScript==
// @name         Cube Cobra Set Shorthand Add
// @namespace    http://tampermonkey.net/
// @version      1.4
// @description  Type "EOE 331", hit Enter to resolve to "Chorale of the Void [EOE-331]", hit Enter again to add
// @author       You
// @match        https://cubecobra.com/*
// @grant        GM_xmlhttpRequest
// @connect      api.scryfall.com
// ==/UserScript==

(function () {
  'use strict';

  const SHORTHAND_RE = /^([A-Za-z0-9]{2,6})\s+(\d+[A-Za-z]?)$/;
  const FORMATTED_RE = /\[([A-Za-z0-9]{2,6})-(\d+[A-Za-z]?)\]/;
  const SPLIT_LAYOUTS = new Set(['split', 'aftermath']);

  let activeRequest = null;

  function lookupCard(setCode, collectorNum, onSuccess, onError) {
    if (activeRequest) {
      activeRequest.abort();
      activeRequest = null;
    }
    const url = `https://api.scryfall.com/cards/${setCode.toLowerCase()}/${collectorNum}`;
    activeRequest = GM_xmlhttpRequest({
      method: 'GET',
      url,
      headers: { 'Accept': 'application/json' },
      onload(response) {
        activeRequest = null;
        try {
          const data = JSON.parse(response.responseText);
          if (data.object === 'card') {
            onSuccess(getDisplayName(data));
          } else {
            onError(`Card not found: ${setCode.toUpperCase()} ${collectorNum}`);
          }
        } catch (e) {
          onError('Failed to parse Scryfall response');
        }
      },
      onerror() {
        activeRequest = null;
        onError('Scryfall request failed');
      },
    });
  }
    function getDisplayName(data) {
      if (SPLIT_LAYOUTS.has(data.layout)) {
        // Keep the full "A // B" name
        return data.name;
      }
      // DFC and anything else with // — keep front face only
      if (data.name.includes(' // ')) {
        return data.name.split(' // ')[0];
      }
      return data.name;
    }
  function setNativeValue(input, value) {
    const nativeInputValueSetter = Object.getOwnPropertyDescriptor(
      window.HTMLInputElement.prototype, 'value'
    ).set;
    nativeInputValueSetter.call(input, value);
    input.dispatchEvent(new Event('input', { bubbles: true }));
    input.dispatchEvent(new Event('change', { bubbles: true }));
  }

  function attachToInput(input) {
    if (input.dataset.cubeCobraShorthandAttached) return;
    input.dataset.cubeCobraShorthandAttached = 'true';

    // When true, the next Enter keydown will be allowed through untouched
    let justResolved = false;

    function setStatus(msg, isError = false) {
      let el = input.parentElement.querySelector('.cc-shorthand-status');
      if (!el) {
        el = document.createElement('div');
        el.className = 'cc-shorthand-status';
        Object.assign(el.style, {
          fontSize: '12px',
          marginTop: '3px',
          fontFamily: 'monospace',
          transition: 'opacity 0.3s ease',
        });
        input.parentElement.appendChild(el);
      }
      el.textContent = msg;
      el.style.color = isError ? '#e05c5c' : '#5caadd';
      el.style.opacity = '1';
      if (msg) {
        clearTimeout(el._hideTimer);
        el._hideTimer = setTimeout(() => { el.style.opacity = '0'; }, 3000);
      }
    }

    input.addEventListener('input', () => {
      const val = input.value.trim();
      const match = val.match(SHORTHAND_RE);
      if (match) {
        setStatus(`Will look up ${match[1].toUpperCase()} #${match[2]} on Enter…`);
      } else if (FORMATTED_RE.test(val)) {
        setStatus('Press Enter to add card');
      } else {
        setStatus('');
      }
    });

    input.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter') return;

      // If we just resolved a shorthand, let this Enter pass through to CubeCobra
      if (justResolved) {
        justResolved = false;
        return; // do NOT preventDefault — let CubeCobra handle it
      }

      const val = input.value.trim();

      // Already formatted — pass through
      if (FORMATTED_RE.test(val)) return;

      const match = val.match(SHORTHAND_RE);
      if (!match) return;

      // It's a shorthand — intercept and resolve
      e.preventDefault();
      e.stopImmediatePropagation();

      const [, setCode, collectorNum] = match;
      const upperSet = setCode.toUpperCase();
      setStatus(`Looking up ${upperSet} #${collectorNum}…`);

      lookupCard(setCode, collectorNum,
        (cardName) => {
          const formatted = `${cardName} [${upperSet}-${collectorNum}]`;
          setNativeValue(input, formatted);
          setStatus(`${formatted} — press Enter to add`);
          justResolved = true; // next Enter will pass through
        },
        (errMsg) => {
          setStatus(`${errMsg}`, true);
        }
      );
    }, { capture: true });
  }

  function findAndAttach() {
    document.querySelectorAll([
      'input[placeholder*="Card"]',
      'input[placeholder*="card"]',
      'input[placeholder*="Search"]',
      'input[placeholder*="search"]',
      'input[aria-label*="card"]',
      'input[aria-label*="Card"]',
    ].join(', ')).forEach(attachToInput);
  }

  findAndAttach();
  const observer = new MutationObserver(findAndAttach);
  observer.observe(document.body, { childList: true, subtree: true });

})();
